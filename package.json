{
  "name": "worktree-env",
  "version": "0.1.1",
  "description": "Automatic per-worktree .env management — unique port offsets and string suffixes so parallel git worktrees never collide",
  "type": "module",
  "bin": {
    "worktree-env": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "worktree",
    "git-worktree",
    "env",
    "port-offset",
    "dotenv",
    "isolation",
    "parallel-development"
  ],
  "author": "Cedric Vidal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cedricvidal/worktree-env.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
